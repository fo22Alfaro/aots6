{
  "version": 2,
  "functions": {
    "api/aots6-core.js": {
      "runtime": "nodejs20.x",
      "maxDuration": 10
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*)",     "dest": "/api/aots6-core" }
  ],
  "env": {
    "WALLET": "@wallet",
    "AMOUNT": "@amount"
  }
}
